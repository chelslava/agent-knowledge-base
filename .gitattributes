# Нормализация переносов строк для кросс-платформенной базы знаний.
# По умолчанию git сам определяет текст и хранит в репозитории как LF.
* text=auto eol=lf

# POSIX-скрипты обязаны оставаться LF (CRLF ломает их в bash).
*.sh   text eol=lf

# PowerShell стабильно работает с CRLF на Windows.
*.ps1  text eol=crlf

# Markdown — текст, нормализуем к LF в репозитории.
*.md   text eol=lf
